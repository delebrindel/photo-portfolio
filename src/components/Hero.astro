---
import { getPhotoUrl } from '../lib/photos';

export interface Props {
  featuredPhoto: {
    collection: string;
    gallery: string;
    file: string;
  };
  name: string;
  tagline: string;
  photosBaseUrl: string;
}

const { featuredPhoto, name, tagline, photosBaseUrl } = Astro.props;
const heroUrl = getPhotoUrl(
  photosBaseUrl,
  featuredPhoto.collection,
  featuredPhoto.gallery,
  featuredPhoto.file,
  'full',
);
---

<section class="hero">
  <div class="hero-bg" style={`background-image: url(${heroUrl})`}></div>
  <div class="hero-overlay"></div>
  <div class="hero-content container">
    <h1 class="hero-name">{name}</h1>
    <p class="hero-tagline">{tagline}</p>
  </div>
</section>

<style>
  .hero {
    position: relative;
    height: 85vh;
    min-height: 500px;
    max-height: 900px;
    display: flex;
    align-items: flex-end;
    overflow: hidden;
  }

  .hero-bg {
    position: absolute;
    inset: 0;
    background-size: cover;
    background-position: center;
    background-repeat: no-repeat;
    /* Fallback for when R2 isn't set up yet */
    background-color: var(--color-bg-elevated);
  }

  .hero-overlay {
    position: absolute;
    inset: 0;
    background: linear-gradient(
      to bottom,
      transparent 30%,
      rgba(10, 10, 10, 0.6) 70%,
      var(--color-bg) 100%
    );
  }

  .hero-content {
    position: relative;
    z-index: 1;
    padding-bottom: 4rem;
  }

  .hero-name {
    font-family: var(--font-heading);
    color: var(--color-text);
    margin-bottom: 0.5rem;
    text-shadow: 0 2px 20px rgba(0, 0, 0, 0.5);
  }

  .hero-tagline {
    font-size: clamp(1rem, 2vw, 1.3rem);
    color: var(--color-text-secondary);
    font-style: italic;
    max-width: 40ch;
  }
</style>
